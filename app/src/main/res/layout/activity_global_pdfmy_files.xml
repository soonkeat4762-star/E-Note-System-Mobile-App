<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient3"
    tools:context=".GlobalPDFMyFiles">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <TextView
            android:id="@+id/title_pdf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/baloo"
            android:padding="16dp"
            android:text="@string/personal_pdf_library"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="TextContrastCheck" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/txtsearchMyFiles"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/search_background"
            android:fontFamily="@font/robotocondensed_regular"
            android:layout_marginTop="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:textColor="#000000"
            android:textColorHint="#6E6D6D"
            android:textAlignment="center"
            android:textCursorDrawable="@null"
            android:textSize="14sp"
            app:queryHint="@string/search_pdf_search"
            app:iconifiedByDefault="false"
            app:searchHintIcon="@null"
            android:focusable="false"
            app:closeIcon="@drawable/ic_clear_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_pdf"
            tools:ignore="TouchTargetSizeCheck,TextContrastCheck"/>

        <ImageButton
            android:id="@+id/search_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="@string/searchbtn"
            android:padding="8dp"
            android:layout_marginStart="17dp"
            android:src="@drawable/ic_search_icon"
            app:layout_constraintBottom_toBottomOf="@id/txtsearchMyFiles"
            app:layout_constraintStart_toStartOf="@id/txtsearchMyFiles"
            app:layout_constraintTop_toTopOf="@id/txtsearchMyFiles"
            tools:ignore="TouchTargetSizeCheck,ImageContrastCheck" />

        <ImageButton
            android:id="@+id/clear_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="@string/clearbtn"
            android:layout_marginEnd="10dp"
            android:padding="8dp"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="@id/txtsearchMyFiles"
            app:layout_constraintEnd_toEndOf="@id/txtsearchMyFiles"
            app:layout_constraintTop_toTopOf="@id/txtsearchMyFiles"
            tools:ignore="TouchTargetSizeCheck,ImageContrastCheck" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclePdfMyFiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="25dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:clipToPadding="false"
            android:paddingStart="0dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:scrollbars="vertical"
            app:layout_constraintTop_toBottomOf="@id/txtsearchMyFiles" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.bottomappbar.BottomAppBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:id="@+id/bottomAppBar"
        app:fabCradleMargin="10dp"
        app:fabCradleRoundedCornerRadius="0dp"
        app:fabCradleVerticalOffset="0dp"
        tools:ignore="VisualLintBottomAppBar">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/bottomNavigationView2"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp"
            app:menu="@menu/global_navigate"
            android:background="@drawable/transparrent_background"
            tools:ignore="VisualLintBottomNav" />

    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_add_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/add_icon"
        android:backgroundTint="#87CEFA"
        android:contentDescription="@string/btnadd"
        app:layout_anchor="@id/bottomAppBar"
        app:maxImageSize="35dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>