<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient"
    android:transitionName="transition_login"
    tools:context=".Login">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient"
        android:navigationIcon="@drawable/ic_back"
        android:navigationContentDescription="@string/back"
       app:navigationIconTint="@color/black"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingTop="?attr/actionBarSize"
        android:paddingEnd="40dp">


        <TextView
            android:id="@+id/Login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/robotocondensed_bold"
            android:text="@string/login_title"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:textColor="@color/bluedark"
            android:textSize="50sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/Logo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:layout_marginStart="70dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/logo_icon"
                tools:ignore="ImageContrastCheck" />

        </LinearLayout>

        <RelativeLayout
            android:id="@+id/relative"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.hbb20.CountryCodePicker
                android:id="@+id/login_country_code_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:background="@drawable/rectangle_border"
                android:padding="7dp"
                app:ccp_autoDetectCountry="true"
                app:ccp_showFlag="true"
                app:ccp_showFullName="true"
                app:ccp_showNameCode="true" />


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/login_phone_number"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/login_country_code_picker"
                android:layout_marginTop="10dp"
                android:hint="@string/phone_number"
                android:inputType="textEmailAddress"
                android:textColorHint="@color/gray"
                app:boxStrokeColor="@color/black"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="clear_text"
                app:endIconTint="@color/black"
                app:hintTextColor="@color/black"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:inputType="phone"
                    android:textColor="@color/black"
                    android:textColorHint="#37474F"
                    android:textCursorDrawable="@null"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passBox"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/login_phone_number"
                android:layout_marginTop="10dp"
                android:hint="@string/password"
                android:textColorHint="@color/gray"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/black"
                app:passwordToggleDrawable="@drawable/password_toggle_selector"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/black"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:inputType="textPassword"
                    android:textColor="@color/black"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/forget_password_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/passBox"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/remember_me"
                    style="@style/Widget.AppCompat.CompoundButton.CheckBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:buttonTint="@color/gray"
                    android:contentDescription="@string/rememberme"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:text="@string/remember_me"
                    android:textAllCaps="true"
                    android:textColor="@color/gray"
                    android:textStyle="bold"
                    tools:ignore="ObsoleteLayoutParam" />


                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginStart="30dp"
                    android:layout_weight="1"
                    android:background="#00000000"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:onClick="callForgetPassword"
                    android:text="@string/forget_password"
                    android:textAllCaps="true"
                    android:textColor="@color/gray"
                    android:textStyle="bold"
                    tools:ignore="InefficientWeight,OnClick,TextContrastCheck,VisualLintButtonSize" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/letTheUserLogIn"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/forget_password_block"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_login_register_screen"
                android:fontFamily="@font/cormorantgaramond_semibold"
                android:onClick="callLogin"
                android:text="@string/log"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/login_sign_up_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/letTheUserLogIn"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:background="#00000000"
                android:fontFamily="@font/robotocondensed_regular"
                android:gravity="center_horizontal"
                android:onClick="callSignUpFromLogin"
                android:text="@string/create_account"
                android:textColor="@color/gray"
                android:textStyle="bold"
                android:transitionName="transition_create_account"
                tools:ignore="TextContrastCheck" />

            <RelativeLayout
                android:id="@+id/login_progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_below="@+id/login_country_code_picker"
                android:background="@drawable/loading"
                android:elevation="8dp"
                android:indeterminate="true"
                android:padding="20dp">

                <ProgressBar
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentTop="true" />

            </RelativeLayout>

        </RelativeLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>


