<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient"
    tools:context=".activity.NotePage">


    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient"
        android:navigationIcon="@drawable/ic_back"
        android:navigationContentDescription="@string/back"
        app:navigationIconTint="@color/black"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    <ImageButton
        android:id="@+id/imgsave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="310dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/circle_sava"
        android:contentDescription="@string/app_name"
        android:minWidth="30dp"
        android:minHeight="30dp"
        android:src="@drawable/ic_check"
        tools:ignore="ImageContrastCheck,TouchTargetSizeCheck" />

    <LinearLayout
        android:id="@+id/make_selection_linearlayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="?attr/actionBarSize"
        android:paddingEnd="20dp"
        app:layout_anchor="@+id/make_selection_linearlayout"
        app:layout_anchorGravity="center">

        <EditText
            android:id="@+id/inputtitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="12dp"
            android:background="@null"
            android:fontFamily="@font/baloo"
            android:hint="@string/note_title"
            android:imeOptions="actionDone"
            android:importantForAutofill="no"
            android:includeFontPadding="false"
            android:inputType="text"
            android:textColor="@color/black"
            android:textColorHint="#283593"
            android:textSize="30sp"
            app:layout_constraintTop_toBottomOf="@+id/make_selection_linearlayout"
            tools:ignore="VisualLintTextFieldSize" />

        <TextView
            android:id="@+id/textDateTime"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/amarante_regular"
            android:textColor="@color/bluedark"
            android:textSize="15sp"
            tools:ignore="SmallSp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:id="@+id/viewsubtitle"
                android:layout_width="8dp"
                android:layout_height="55dp"
                android:background="@drawable/subtitle" />

            <EditText
                android:id="@+id/inputsubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/gradient"
                android:fontFamily="@font/changa"
                android:hint="@string/note_subtitle"
                android:importantForAutofill="no"
                android:includeFontPadding="false"
                android:inputType="textMultiLine"
                android:minHeight="48dp"
                android:paddingTop="8dp"
                android:textColor="@color/bluedark"
                android:textColorHint="@color/bluedark"
                android:textSize="17sp"
                tools:ignore="VisualLintTextFieldSize" />


        </LinearLayout>

        <EditText
            android:id="@+id/textedit"
            android:layout_width="match_parent"
            android:layout_height="474dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="15dp"
            android:background="@null"
            android:fontFamily="@font/arbutus_regular"
            android:gravity="top"
            android:hint="@string/type_note_here"
            android:importantForAutofill="no"
            android:includeFontPadding="false"
            android:inputType="textMultiLine"
            android:minHeight="100dp"
            android:textColor="@color/black"
            android:textColorHint="#283593"
            android:textSize="13sp"
            tools:ignore="VisualLintTextFieldSize" />

    </LinearLayout>

   <include layout="@layout/layout_miscellaneous"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>



