<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PdfEditActivity">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient13"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 返回上一页 -->
        <ImageView
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="1dp"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/back_btn"
            android:src="@drawable/ic_back" />

        <!-- 编辑模式切换按钮 -->
        <ImageView
            android:id="@+id/toggle_edit_mode1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="15dp"
            android:background="@drawable/button_toggle_edit_mode_selector"
            android:contentDescription="@string/toggle_edit_mode"
            android:padding="8dp"
            android:src="@drawable/icon_edit_ic"
            tools:ignore="ImageContrastCheck" />

        <!-- 显示工具栏按钮 -->
        <ImageView
            android:id="@+id/show_toolbar_button1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_show_toolbar"
            android:layout_weight="1"
            android:layout_marginStart="210dp"
            android:contentDescription="@string/show_toolbar_button"
            app:layout_constraintEnd_toEndOf="parent" />

    </LinearLayout>



    <!-- 画布 -->
    <com.github.barteksc.pdfviewer.PDFView
        android:id="@+id/pdfView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintBottom_toTopOf="@id/optionsHolder1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- 自定义绘制View -->
    <com.android.noteapp.PDFDrawingView
        android:id="@+id/pdfDrawingView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/optionsHolder1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <LinearLayout
        android:id="@+id/optionsHolder1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient13"
        android:orientation="horizontal"
        android:padding="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 笔刷粗细调整器 -->
        <SeekBar
            android:id="@+id/brush_size_seekbar1"
            android:layout_width="0dp"
            android:layout_height="15dp"
            android:layout_marginVertical="10dp"
            android:layout_weight="2"
            android:progressDrawable="@drawable/seekbar_progress"
            android:thumb="@drawable/seekbar_thumb"
            android:max="100"
            android:progress="1" />

        <TextView
            android:id="@+id/txtPenSize1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:fontFamily="@font/robotocondensed_regular"
            android:layout_marginEnd="15dp"
            android:layout_marginVertical="5dp"
            android:text="@string/_0dp"/>

        <!-- 调色板 -->
        <ImageView
            android:id="@+id/color_palette_tool1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/tool_palette"
            android:src="@drawable/palette" />

        <!-- 保存按钮 -->
        <ImageView
            android:id="@+id/save_button1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:background="@drawable/save"
            android:contentDescription="@string/savebutton"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="TouchTargetSizeCheck,ImageContrastCheck" />

    </LinearLayout>

    <!-- 弹出菜单或对话框 -->
    <LinearLayout
        android:id="@+id/tool_dialog1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient13"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- 铅笔工具 -->
        <ImageView
            android:id="@+id/pencil_tool1"
            android:layout_width="wrap_content"
            android:paddingBottom="15dp"
            android:layout_height="wrap_content"
            android:contentDescription="@string/tool_pencil"
            android:src="@drawable/ic_pencil_tools" />

        <!-- 钢笔工具 -->
        <ImageView
            android:id="@+id/pen_tool1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="15dp"
            android:contentDescription="@string/tools_pen"
            android:src="@drawable/ic_pen_tools" />

        <!-- 荧光笔工具 -->
        <ImageView
            android:id="@+id/highlighter_tool1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="15dp"
            android:contentDescription="@string/tools_highlighter"
            android:src="@drawable/highlight_tool" />

        <!-- 毛笔工具 -->
        <ImageView
            android:id="@+id/brush_tool1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="15dp"
            android:contentDescription="@string/tool_brush"
            android:src="@drawable/ic_brush_tools" />

        <!-- 画笔工具 -->
        <ImageView
            android:id="@+id/paint_tool1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="15dp"
            android:contentDescription="@string/tool_paint"
            android:src="@drawable/ic_paint_tools" />

        <ImageView
            android:id="@+id/eraser1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="15dp"
            android:contentDescription="@string/erasers"
            android:src="@drawable/ic_eraser_tools" />

        <!-- 撤销按钮 -->
        <ImageView
            android:id="@+id/undo_button1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/undo"
            android:paddingBottom="15dp"
            android:src="@drawable/undo_ic" />
        <!-- 重做按钮 -->
        <ImageView
            android:id="@+id/redo_button1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="15dp"
            android:contentDescription="@string/redo"
            android:src="@drawable/ic_redo" />

        <!-- 清除画布按钮 -->
        <ImageView
            android:id="@+id/clear_button1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/clear"
            android:src="@drawable/ic_clear" />
    </LinearLayout>

    <!-- 缩略图 RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/thumbnailRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

</androidx.constraintlayout.widget.ConstraintLayout>