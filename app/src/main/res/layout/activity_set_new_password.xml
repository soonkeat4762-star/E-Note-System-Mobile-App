<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient"
    android:id="@+id/make_set_new_password_scroll_view"
    android:transitionName="transition_set_new_password"
    tools:context=".SetNewPassword">


    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient"
        android:navigationIcon="@drawable/ic_back"
        android:navigationContentDescription="@string/back"
        app:navigationIconTint="@color/black"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    <LinearLayout
        android:id="@+id/make_selection_linearlayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="?attr/actionBarSize">

        <ImageView
            android:id="@+id/set_new_password_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="50dp"
            android:src="@drawable/ic_new_password"
            android:contentDescription="@string/logo_new_password" />

        <TextView
            android:id="@+id/set_new_password_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/muli_black"
            android:gravity="center"
            android:text="@string/new_ncredentials"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:textColor="@color/black"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/set_new_password_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/muli_semibolditalic"
            android:gravity="center"
            android:text="@string/new_credentials_details"
            android:textAlignment="center"
            android:textColor="@color/gray"
            android:textSize="16sp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/new_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:hint="@string/new_password"
                android:textColorHint="@color/gray"
                app:boxBackgroundColor="@color/lightWhite"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/black"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@drawable/baseline_lock"
                app:passwordToggleDrawable="@drawable/password_toggle_selector"
                app:hintTextColor="@color/black"
                app:startIconTint="@color/black">


                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:textColor="@color/black"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    tools:ignore="VisualLintTextFieldSize" />

            </com.google.android.material.textfield.TextInputLayout>


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/confirm_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/new_password"
                android:layout_marginTop="10dp"
                android:hint="@string/confirm_password"
                android:textColorHint="@color/gray"
                app:boxBackgroundColor="@color/lightWhite"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/black"
                app:startIconDrawable="@drawable/baseline_lock"
                app:startIconTint="@color/black"
                app:passwordToggleTint="@color/black"
                app:passwordToggleEnabled="true"
                app:passwordToggleDrawable="@drawable/password_toggle_selector"
                app:hintTextColor="@color/black">


                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:textColor="@color/black"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:textCursorDrawable="@null"
                    tools:ignore="VisualLintTextFieldSize" />


            </com.google.android.material.textfield.TextInputLayout>


            <Button
                android:id="@+id/set_new_password_btn"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:layout_below="@id/confirm_password"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_update_screen"
                android:onClick="setNewPasswordBtn"
                android:text="@string/update"
                android:fontFamily="@font/robotocondensed_bold"
                android:textStyle="bold"
                android:elevation="5dp"
                android:layout_gravity="center"
                android:layout_centerHorizontal="true"
                android:textColor="@color/white"
                android:transitionName="transition_next_btn"/>

        </RelativeLayout>
</LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>