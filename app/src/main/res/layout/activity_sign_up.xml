<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient3"
    android:transitionName="transition_signup"
    tools:context=".SignUp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient3"
        android:navigationIcon="@drawable/ic_back"
        android:navigationContentDescription="@string/back"
        app:navigationIconTint="@color/black"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="?attr/actionBarSize">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/signup_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:fontFamily="@font/muli_semibold"
                android:text="@string/create_account"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textSize="34sp"
                android:transitionName="transition_title_text"
                tools:ignore="RelativeOverlap" />

            <TextView
                android:id="@+id/signup_slide_text"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginTop="20dp"
                android:background="@drawable/circle_border"
                android:fontFamily="@font/ds_digital"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/_1_3"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="30sp"
                android:transitionName="transition_slide_text" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/signup_fullname"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/full_name"
                android:textColorHint="@color/gray"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="clear_text"
                app:endIconContentDescription="@string/clear_text"
                app:endIconTint="@color/black"
                app:hintTextColor="@color/black"
                app:startIconDrawable="@drawable/fullname"
                app:startIconTint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputFullName"

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:inputType="text"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />
            </com.google.android.material.textfield.TextInputLayout>



            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/signup_username"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_username"
                android:textColorHint="@color/gray"
                app:boxStrokeColor="@color/white"
                android:layout_marginTop="10dp"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="clear_text"
                app:endIconTint="@color/black"
                app:hintTextColor="@color/black"
                app:startIconDrawable="@drawable/ic_username"
                app:startIconTint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputUsername"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:inputType="text"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/signup_email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_email"
                app:endIconMode="clear_text"
                android:layout_marginTop="10dp"
                app:endIconTint="@color/black"
                app:hintTextColor="@color/black"
                app:startIconDrawable="@drawable/baseline_email_24"
                app:startIconTint="@color/black"
                android:textColorHint="@color/gray"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidthFocused="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputEmail"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    tools:ignore="VisualLintTextFieldSize" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/signup_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColorHint="@color/gray"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidthFocused="2dp"
                android:layout_marginTop="10dp"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@drawable/baseline_lock"
                android:hint="@string/password"
                app:startIconTint="@color/black"
                app:passwordToggleTint="@color/black"
                app:passwordToggleDrawable="@drawable/password_toggle_selector"
                app:hintTextColor="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputPassword"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#38ffffff"
                    android:drawablePadding="20dp"
                    android:fontFamily="@font/robotocondensed_regular"
                    android:inputType="textPassword"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/signup_next_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/btn_login_register_screen"
            android:fontFamily="@font/robotocondensed_bold"
            android:textStyle="bold"
            android:elevation="5dp"
            android:layout_gravity="center"
            android:layout_centerHorizontal="true"
            android:onClick="callNextSigupScreen"
            android:text="@string/tonext"
            android:textColor="@color/white"
            android:transitionName="transition_next_btn"
            tools:ignore="ObsoleteLayoutParam" />

        <Button
            android:id="@+id/signup_login_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:background="#00000000"
            android:elevation="5dp"
            android:fontFamily="@font/robotocondensed_bold"
            android:onClick="callLoginFromSignUp"
            android:text="@string/login"
            android:textColor="@color/white"
            android:transitionName="transition_login_btn"
            tools:ignore="TextContrastCheck" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

