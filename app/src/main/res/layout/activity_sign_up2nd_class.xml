<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient3"
    android:transitionName="transition_signup"
    tools:context=".SignUp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient3"
        android:navigationIcon="@drawable/ic_back"
        android:navigationContentDescription="@string/back"
        app:navigationIconTint="@color/black"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="?attr/actionBarSize">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/signup_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/muli_semibold"
                android:text="@string/create_account"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textSize="34sp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:transitionName="transition_title_text"
                tools:ignore="RelativeOverlap" />

            <TextView
                android:id="@+id/signup_slide_text"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:fontFamily="@font/ds_digital"
                android:text="@string/_2_3"
                android:background="@drawable/circle_border"
                android:textColor="@color/black"
                android:textSize="30sp"
                android:gravity="center"
                android:padding="10dp"
                android:textAlignment="center"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:transitionName="transition_slide_text" />

        </RelativeLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_gender"
                android:textColor="@color/black"
                android:textSize="18sp"/>

            <RadioGroup
                android:id="@+id/radio_group"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/male"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/black"
                    android:textColor="@color/black"
                    android:text="@string/male" />

                <RadioButton
                    android:id="@+id/female"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/black"
                    android:textColor="@color/black"
                    android:layout_marginStart="10dp"
                    android:text="@string/female" />

                <RadioButton
                    android:id="@+id/others"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/black"
                    android:textColor="@color/black"
                    android:layout_marginStart="10dp"
                    android:text="@string/other" />
            </RadioGroup>


            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:background="@color/black" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_your_age"
                android:textColor="@color/black"
                android:textSize="18sp" />


            <DatePicker
                android:id="@+id/age_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:calendarViewShown="false"
                android:datePickerMode="spinner"
                android:spinnersShown="true"
                android:theme="@style/CustomDatePickerTheme" />


        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/signup_next_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:minWidth="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/btn_login_register_screen"
            android:fontFamily="@font/robotocondensed_bold"
            android:textStyle="bold"
            android:elevation="5dp"
            android:layout_gravity="center"
            android:onClick="call3rdSigupScreen"
            android:text="@string/tonext"
            android:textColor="@color/white"
            android:transitionName="transition_next_btn"
            tools:ignore="OnClick" />


        <Button
            android:id="@+id/signup_login_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:background="#00000000"
            android:elevation="5dp"
            android:fontFamily="@font/robotocondensed_bold"
            android:onClick="callLoginFromSignUp"
            android:text="@string/login"
            android:textColor="@color/white"
            android:transitionName="transition_login_btn"
            tools:ignore="TextContrastCheck" />


    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>