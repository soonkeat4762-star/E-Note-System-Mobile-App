<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient3"
    tools:context=".UploadGlobalPdf">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient3"
        android:navigationIcon="@drawable/ic_back"
        android:navigationContentDescription="@string/back"
        app:navigationIconTint="@color/black"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="?attr/actionBarSize"
        android:gravity="center_horizontal">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="650dp"
        android:background="#E5F5FE"
        tools:ignore="UselessParent">

        <ImageView
            android:id="@+id/upload_icon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="48dp"
            android:contentDescription="@string/images_pdfupload"
            android:src="@drawable/upload_pdf"
            tools:ignore="ImageContrastCheck" />

        <TextView
            android:id="@+id/upload_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_your_pdf_global"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_below="@id/upload_icon"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/upload_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/description_global_pdf"
            android:textSize="18sp"
            android:textColor="#003399"
            android:textStyle="bold"
            android:layout_below="@id/upload_title"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp" />

        <EditText
            android:id="@+id/fileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/upload_hint"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="20dp"
            android:hint="@string/file_name_global"
            android:inputType="text"
            android:minHeight="48dp"
            tools:ignore="VisualLintTextFieldSize"
            android:autofillHints="" />

        <Button
            android:id="@+id/upload_pdf"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_below="@id/fileName"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp"
            android:background="@drawable/btn_shape"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="@string/select_file"
            android:textColor="#ffffff"
            android:textSize="16sp"
            tools:ignore="TextContrastCheck" />

        <ProgressBar
            android:id="@+id/upload_progressbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_below="@id/upload_pdf"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp"/>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/upload_global_progress_bar"
            android:layout_centerInParent="true"
            android:background="@drawable/loading"
            android:elevation="8dp"
            android:padding="20dp">

            <ProgressBar
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentTop="true"/>

        </RelativeLayout>

    </RelativeLayout>
</LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>